\textbf{检验项} & \textbf{计算} & \textbf{结果} \\
\hline
头的总数 & $6 + 4 = 10$ & \checkmark \\
\hline
腿的总数 & $6 \times 2 + 4 \times 4 = 12 + 16 = 28$ & \checkmark \\
\hline
\end{tabular}
\end{center}

